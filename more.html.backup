<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>More — Spiralarc AI</title>
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-3E7RV5FHGR"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-3E7RV5FHGR');
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;500;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #78C2CE;
      --text: #222;
      --muted: #666;
      --line: #6FB3BE;
      --accent: #01696f;
      --max: 960px;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: "Inter", "Aktiv Grotesk", "Helvetica Neue", Arial, sans-serif;
      font-weight: 300;
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
    }

    h1, h2, h3 {
      font-family: "Inter", "Univers", "Helvetica Neue", Helvetica, Arial, sans-serif;
      font-weight: 500;
    }

    .wrap {
      width: min(100% - 2rem, var(--max));
      margin: 0 auto;
    }

    header {
      position: sticky;
      top: 0;
      background: rgba(120,194,206,.92);
      border-bottom: 1px solid var(--line);
      backdrop-filter: blur(8px);
    }

    nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1rem 0;
    }

    nav ul {
      display: flex;
      list-style: none;
      gap: 1rem;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    nav a:hover {
      text-decoration: underline;
      text-underline-offset: 0.3em;
    }

    .btn {
      display: inline-block;
      padding: .8rem 1rem;
      background: var(--accent);
      color: white;
      border-radius: .5rem;
    }

    section {
      padding: 5rem 0;
      border-bottom: 1px solid var(--line);
    }

    h1 { font-size: clamp(2.2rem, 6vw, 4.5rem); line-height: 1.05; margin-bottom: 1rem; }
    h2 { font-size: 1.5rem; margin-bottom: .75rem; }
    p  { max-width: 60ch; color: var(--muted); }

    footer {
      padding: 2rem 0 4rem;
      color: var(--muted);
    }

    @media (max-width: 700px) {
      nav { flex-direction: column; gap: .75rem; }
      nav ul { flex-wrap: wrap; justify-content: center; }
    }
  </style>
</head>
<body>
  <header>
    <div class="wrap">
      <nav>
        <a href="index.html">spiralarc</a>
        <ul>
          <li><a href="index.html#about">About</a></li>
          <li><a href="https://www.superprof.co.uk/artificial-intelligence-and-agentic-coach-from-basic-skills-robust-agent-workflows-can-show-you-the-way.html" target="_blank" rel="noopener">Learn with Martin</a></li>
          <li><a href="index.html#contact">Contact</a></li>
        </ul>
      </nav>
    </div>
  </header>

  <main class="wrap">
    <section>
      <h1>More</h1>
      <p>Content coming soon.</p>
    </section>
  </main>

  <footer class="wrap">
    <p>© 2026 spiralarc</p>
  </footer>
</body>
</html>
